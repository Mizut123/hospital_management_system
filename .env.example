# =============================================================================
# HOSPITAL MANAGEMENT SYSTEM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and configure for your environment
# NEVER commit .env to version control!

# =============================================================================
# CRITICAL SECURITY SETTINGS
# =============================================================================

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-super-secret-key-generate-new-one

# Set to False in production (True only for development)
DEBUG=False

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# HTTPS/SSL SETTINGS (Enable in production with HTTPS)
# =============================================================================

# Redirect all HTTP to HTTPS
SECURE_SSL_REDIRECT=False

# HTTP Strict Transport Security (HSTS) - set to 31536000 (1 year) in production
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Secure cookies - set to True when using HTTPS
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Use SQLite for development, PostgreSQL for production
USE_SQLITE=True

# PostgreSQL settings (required when USE_SQLITE=False)
DB_NAME=hospital_db
DB_USER=hospital_user
DB_PASSWORD=strong-database-password-here
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=prefer

# =============================================================================
# DATA ENCRYPTION (Required for PHI protection)
# =============================================================================

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# =============================================================================
# PRODUCTION CHECKLIST
# =============================================================================
# Before deploying to production, ensure:
# [ ] SECRET_KEY is set to a unique, random value
# [ ] DEBUG=False
# [ ] ALLOWED_HOSTS contains only your domain(s)
# [ ] USE_SQLITE=False (use PostgreSQL)
# [ ] All SECURE_* and *_COOKIE_SECURE settings are True
# [ ] FIELD_ENCRYPTION_KEY is set for PHI encryption
# [ ] Database credentials are strong and unique
# [ ] SSL certificate is installed
# [ ] Regular backups are configured
